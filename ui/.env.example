# Copy to ".env" and fill in values before running `docker compose up --build`.
# These are baked into the browser bundle at build time, so ONLY put public,
# browser-safe values here (never the Stripe secret key).

# Base URL the SPA uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:8080

# Google Maps JavaScript API key (browser key). Used by the address MapPicker.
# The Stripe PUBLISHABLE key is NOT needed here — the frontend fetches it from
# the backend at runtime via GET /api/payments/config.
VITE_GOOGLE_MAPS_KEY=
